{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "dev:ipad": "VITE_DEV_HTTPS=1 vite --host 0.0.0.0 --port 5174",
    "dev:test": "vite --mode test",
    "build": "vite build",
    "build:test": "vite build --mode test",
    "preview": "vite preview",
    "preview:test": "vite preview --mode test",
    "app:dev": "PORT=5052 HOST=127.0.0.1 NODE_ENV=development APP_ENV=development VITE_MODE=development node --env-file=.env.development --env-file-if-exists=.env.development.local --import tsx server/index.ts",
    "app:dev:https": "PORT=5052 HOST=127.0.0.1 NODE_ENV=development APP_ENV=development VITE_MODE=development APP_DEV_HTTPS=1 node --env-file=.env.development --env-file-if-exists=.env.development.local --import tsx server/index.ts",
    "app:dev:test": "NODE_ENV=development APP_ENV=test VITE_MODE=test node --env-file=.env.test --env-file-if-exists=.env.test.local --import tsx server/index.ts",
    "app:build:production": "NODE_ENV=production APP_ENV=production VITE_MODE=production node --env-file=.env.production --env-file-if-exists=.env.production.local --import tsx script/build.ts",
    "app:build:test": "NODE_ENV=production APP_ENV=test VITE_MODE=test node --env-file=.env.test --env-file-if-exists=.env.test.local --import tsx script/build.ts",
    "app:start:production": "NODE_ENV=production APP_ENV=production node --env-file=.env.production --env-file-if-exists=.env.production.local dist/index.cjs",
    "app:start:test": "NODE_ENV=production APP_ENV=test node --env-file=.env.test --env-file-if-exists=.env.test.local dist/index.cjs",
    "app:build:host": "NODE_ENV=production APP_ENV=production VITE_MODE=production node --import tsx script/build.ts",
    "app:start:host": "NODE_ENV=production APP_ENV=production node dist/index.cjs",
    "smoke:production": "NODE_ENV=production APP_ENV=production node --env-file=.env.production --env-file-if-exists=.env.production.local script/smoke-predeploy.mjs",
    "smoke:test": "NODE_ENV=production APP_ENV=test node --env-file=.env.test --env-file-if-exists=.env.test.local script/smoke-predeploy.mjs",
    "smoke:host": "NODE_ENV=production APP_ENV=production node script/smoke-predeploy.mjs",
    "predeploy:production": "npm run app:build:production && npm run smoke:production",
    "predeploy:test": "npm run app:build:test && npm run smoke:test",
    "db:push:host": "node ./node_modules/drizzle-kit/bin.cjs push",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "tsc",
    "db:push": "npm run db:push:development",
    "db:push:development": "node --env-file=.env.development --env-file-if-exists=.env.development.local ./node_modules/drizzle-kit/bin.cjs push",
    "db:push:test": "node --env-file=.env.test --env-file-if-exists=.env.test.local ./node_modules/drizzle-kit/bin.cjs push",
    "db:push:production": "node --env-file=.env.production --env-file-if-exists=.env.production.local ./node_modules/drizzle-kit/bin.cjs push"
  },
